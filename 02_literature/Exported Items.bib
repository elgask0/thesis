@article{radovanovicetal-2023-carbonawarecomputingdatacenters,
  title = {Carbon-{{Aware Computing}} for {{Datacenters}}},
  author = {Radovanovi{\'c}, Ana and Koningstein, Ross and Schneider, Ian and Chen, Bokan and Duarte, Alexandre and Roy, Binz and Xiao, Diyue and Haridasan, Maya and Hung, Patrick and Care, Nick and Talukdar, Saurav and Mullen, Eric and Smith, Kendal and Cottman, MariEllen and Cirne, Walfredo},
  year = 2023,
